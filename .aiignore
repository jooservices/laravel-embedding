# Same basic ignores as git
/vendor/
/node_modules/
.idea/
.vscode/

# Ignore massive lock files that waste AI context
composer.lock
package-lock.json
yarn.lock
pnpm-lock.yaml

# Testing & Artifacts
/.phpunit.result.cache
/.phpunit.cache/
/.php-cs-fixer.cache
/coverage/
/coverage.txt
/coverage.xml
/build/
*.log

# Ignore media files
*.png
*.jpg
*.jpeg
*.gif
*.mp4
*.mp3
*.md~
.DS_Store

# DB data
*.sqlite
*.db

# AI Specific (avoid recursive loops or huge generated tokens)
.gemini/
.cursor/
.windsurf/
